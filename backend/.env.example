PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/bank_management

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=15m

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN supports comma-separated origins (example:
# https://bankease-frontend.onrender.com,http://localhost:3000)

# Auth cookie policy (important for cross-domain frontend/backend deploys).
# Leave empty to use secure defaults from code.
# For Render with separate frontend/backend domains:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
COOKIE_SAME_SITE=
COOKIE_SECURE=
# Optional cookie domain, example: .yourdomain.com
COOKIE_DOMAIN=

# Protected admin identity defaults are already hard-coded.
# Use ALLOW_EXTRA_ADMINS=true only if bank policy allows multi-admin bootstrap.
ALLOW_EXTRA_ADMINS=false
ADMIN_EMAILS=
ADMIN_PHONES=

# Payment Gateway
# Allowed values: MOCK, RAZORPAY
PAYMENT_GATEWAY_MODE=MOCK
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Beneficiary transfer enforcement
ENFORCE_BENEFICIARY=false
# Keep true to allow transfer using account number + MPIN even if beneficiary is not verified.
ALLOW_DIRECT_TRANSFER_WITH_PIN=true
HIGH_VALUE_TRANSFER_THRESHOLD=50000
REQUIRE_TRANSFER_OTP_FOR_HIGH_VALUE=false
MAX_SINGLE_TRANSFER=200000
DAILY_TRANSFER_LIMIT=500000
MAX_SINGLE_WITHDRAWAL=100000
DAILY_WITHDRAWAL_LIMIT=200000

# Email service via Nodemailer (password reset, OTP)
# EMAIL_TRANSPORT: service | smtp
EMAIL_TRANSPORT=service
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=false
# Set true only for local testing if your environment has TLS certificate chain issues.
EMAIL_ALLOW_INVALID_TLS=false
# For Gmail: use EMAIL_USER as your gmail id and EMAIL_PASSWORD as 16-digit App Password.
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=BankIndia
EMAIL_FROM_ADDRESS=
# In production this should be false. In development, true allows fallback OTP code in API response.
ALLOW_EMAIL_OTP_FALLBACK=false
# Legacy switch for beneficiary-only fallback support.
ALLOW_BENEFICIARY_OTP_FALLBACK=false

# Admin approval workflow (optional)
# ADMIN_APPROVAL_MODE: DISABLED | ENABLED
ADMIN_APPROVAL_MODE=DISABLED
# When mode is ENABLED and this is empty, all critical actions require approval.
# Supported values: PAYMENT_REFUND, LOAN_STATUS_UPDATE, ACCOUNT_STATUS_UPDATE, TRANSFER_EXECUTION, SIP_PLAN_CREATION, FD_BOOKING_CREATE, RD_CREATION, GL_MANUAL_JOURNAL, MONEY_OUT_POLICY_UPDATE, REGULATORY_POLICY_UPDATE, TREASURY_SNAPSHOT_CREATE, REGULATORY_REPORT_PUBLISH, REGULATORY_ALERT_RESOLVE
ADMIN_APPROVAL_REQUIRED_ACTIONS=
# Optional strict maker-checker enforcement (requester cannot approve/reject own request)
ADMIN_APPROVAL_ENFORCE_DUAL_CONTROL=false
# Optional policy to require review note on approve/reject decision
ADMIN_APPROVAL_REQUIRE_REVIEW_NOTE=false
# SLA/alert windows for pending approval workflow
ADMIN_APPROVAL_SLA_HOURS=24
ADMIN_APPROVAL_ESCALATION_HOURS=48

# Rate limiting controls (per IP)
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=150
LOGIN_RATE_LIMIT_MAX=25
REGISTER_RATE_LIMIT_MAX=20
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=10
RECIPIENT_LOOKUP_RATE_LIMIT_WINDOW_MINUTES=15
RECIPIENT_LOOKUP_RATE_LIMIT_MAX=90
MONEY_OUT_RATE_LIMIT_WINDOW_MINUTES=15
MONEY_OUT_RATE_LIMIT_MAX=60
PAYMENT_WRITE_RATE_LIMIT_WINDOW_MINUTES=15
PAYMENT_WRITE_RATE_LIMIT_MAX=100

# Core banking scheduler and interest engine
CORE_BANKING_SCHEDULER_ENABLED=true
CORE_BANKING_SCHEDULER_INTERVAL_MS=3600000
STANDING_INSTRUCTION_PROCESSOR_ENABLED=true
STANDING_INSTRUCTION_PROCESS_INTERVAL_MS=60000
STANDING_INSTRUCTION_BATCH_LIMIT=25
SAVINGS_INTEREST_ANNUAL_RATE=3.5
AML_SCAN_INTERVAL_HOURS=6
REGULATORY_CTR_THRESHOLD=1000000
REGULATORY_MIN_LCR_RATIO=100
REGULATORY_MAX_LOAN_TO_DEPOSIT_RATIO=90
REGULATORY_OPEN_STR_ALERT_THRESHOLD=1
REGULATORY_CRITICAL_STR_ALERT_THRESHOLD=1
REGULATORY_AUTO_PUBLISH_ENABLED=true
REGULATORY_AUTO_PUBLISH_DAY=1
REGULATORY_AUTO_PUBLISH_HOUR=6
REGULATORY_AUTO_PUBLISH_CTR_THRESHOLD=1000000
REGULATORY_BREACH_MONITOR_ENABLED=true
REGULATORY_BREACH_MONITOR_HOUR=7
# Optional override; set 0 to use policy/environment default CTR threshold.
REGULATORY_BREACH_MONITOR_CTR_THRESHOLD=0

# Deposit products defaults
FD_INTEREST_RATE_DEFAULT=6.8
FD_PREMATURE_PENALTY_RATE=1
FD_AUTO_RENEW_USE_CURRENT_RATE=false
FD_AUTO_RENEW_SCHEDULER_ENABLED=true
FD_AUTO_RENEW_HOUR=8
FD_AUTO_RENEW_BATCH_SIZE=200
RD_INTEREST_RATE_DEFAULT=6.5
RD_PREMATURE_PENALTY_RATE=1
RD_AUTO_DEBIT_SCHEDULER_ENABLED=true
RD_AUTO_DEBIT_BATCH_SIZE=200
RD_AUTO_DEBIT_RETRY_DELAY_HOURS=24
RD_AUTO_DEBIT_MAX_CONSECUTIVE_FAILURES=3

# UPI/VPA simulation
UPI_HANDLE_DOMAIN=bankease
