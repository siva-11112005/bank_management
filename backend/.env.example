PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/bank_management

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=15m

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Protected admin identity defaults are already hard-coded.
# Use ALLOW_EXTRA_ADMINS=true only if bank policy allows multi-admin bootstrap.
ALLOW_EXTRA_ADMINS=false
ADMIN_EMAILS=
ADMIN_PHONES=

# Payment Gateway
# Allowed values: MOCK, RAZORPAY
PAYMENT_GATEWAY_MODE=MOCK
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Beneficiary transfer enforcement
ENFORCE_BENEFICIARY=false
# Keep true to allow transfer using account number + MPIN even if beneficiary is not verified.
ALLOW_DIRECT_TRANSFER_WITH_PIN=true
HIGH_VALUE_TRANSFER_THRESHOLD=50000
REQUIRE_TRANSFER_OTP_FOR_HIGH_VALUE=false
MAX_SINGLE_TRANSFER=200000
DAILY_TRANSFER_LIMIT=500000
MAX_SINGLE_WITHDRAWAL=100000
DAILY_WITHDRAWAL_LIMIT=200000

# Email service via Nodemailer (password reset, OTP)
# EMAIL_TRANSPORT: service | smtp
EMAIL_TRANSPORT=service
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=false
# Set true only for local testing if your environment has TLS certificate chain issues.
EMAIL_ALLOW_INVALID_TLS=false
# For Gmail: use EMAIL_USER as your gmail id and EMAIL_PASSWORD as 16-digit App Password.
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=BankIndia
EMAIL_FROM_ADDRESS=
# In production this should be false. In development, true allows fallback OTP code in API response.
ALLOW_EMAIL_OTP_FALLBACK=false
# Legacy switch for beneficiary-only fallback support.
ALLOW_BENEFICIARY_OTP_FALLBACK=false

# Admin approval workflow (optional)
# ADMIN_APPROVAL_MODE: DISABLED | ENABLED
ADMIN_APPROVAL_MODE=DISABLED
# When mode is ENABLED and this is empty, all critical actions require approval.
# Supported values: PAYMENT_REFUND, LOAN_STATUS_UPDATE, ACCOUNT_STATUS_UPDATE
ADMIN_APPROVAL_REQUIRED_ACTIONS=
# Optional strict maker-checker enforcement (requester cannot approve/reject own request)
ADMIN_APPROVAL_ENFORCE_DUAL_CONTROL=false
# Optional policy to require review note on approve/reject decision
ADMIN_APPROVAL_REQUIRE_REVIEW_NOTE=false
# SLA/alert windows for pending approval workflow
ADMIN_APPROVAL_SLA_HOURS=24
ADMIN_APPROVAL_ESCALATION_HOURS=48

# Rate limiting controls (per IP)
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=150
LOGIN_RATE_LIMIT_MAX=25
REGISTER_RATE_LIMIT_MAX=20
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=10
MONEY_OUT_RATE_LIMIT_WINDOW_MINUTES=15
MONEY_OUT_RATE_LIMIT_MAX=60
PAYMENT_WRITE_RATE_LIMIT_WINDOW_MINUTES=15
PAYMENT_WRITE_RATE_LIMIT_MAX=100
